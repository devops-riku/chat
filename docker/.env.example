# =============================================================================
# Nexus Chat - Environment Configuration
# Copy to .env and adjust for your environment
# =============================================================================

# General
APP_NAME=NexusChat
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production

# Domains (used by Traefik routing)
DOMAIN=localhost
API_HOST=api.localhost
APP_HOST=app.localhost

# PostgreSQL
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_secret
POSTGRES_DB=nexus_chat
DATABASE_URL=postgresql+asyncpg://nexus:nexus_secret@postgres:5432/nexus_chat

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# CORS
CORS_ORIGINS=http://app.localhost,http://localhost:3000,http://127.0.0.1:3000

# Frontend (public) — use localhost when running without Traefik (default on Windows)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SOCKET_URL=http://localhost:8000
# With Traefik + hosts file: http://api.localhost
NEXT_PUBLIC_TURN_URL=turn:localhost:3478
NEXT_PUBLIC_TURN_USERNAME=nexus
NEXT_PUBLIC_TURN_CREDENTIAL=nexus_turn_secret

# Coturn
TURN_REALM=nexus.local
TURN_USER=nexus
TURN_PASSWORD=nexus_turn_secret

# Rate limiting
RATE_LIMIT_PER_MINUTE=120
